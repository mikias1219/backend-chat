/// Chat domain: users, rooms (direct + group), messages, receipts, attachments.
/// Relationships are cascade-deleted from Room → members/messages/uploads.
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Participant in the system; owns memberships, messages, receipts, uploads.
model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  name         String
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships RoomMember[]
  messages    Message[]
  receipts    MessageReceipt[]
  uploads     Attachment[]     @relation("UserUploads")
}

enum RoomType {
  DIRECT
  GROUP
}

/// Conversation container: either a GROUP with many members or DIRECT (two users, unique directKey).
model Room {
  id        String   @id @default(uuid())
  name      String
  type      RoomType @default(GROUP)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  RoomMember[]
  messages Message[]
  uploads  Attachment[]

  /// For DIRECT rooms only: stable key "userA:userB" (sorted ids) for idempotent room lookup.
  directKey String? @unique

  @@index([type, updatedAt])
}

/// Join table: which users belong to which room + per-user read pointers.
model RoomMember {
  roomId            String
  userId            String
  role              RoomRole  @default(MEMBER)
  joinedAt          DateTime  @default(now())
  lastReadAt        DateTime?
  lastReadMessageId String?

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId])
  @@index([roomId, lastReadAt])
  @@index([roomId, joinedAt])
}

enum RoomRole {
  OWNER
  MEMBER
}

/// A chat line item; optional thread link via replyToId (same room only, enforced in app layer).
model Message {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  body      String
  replyToId String?
  createdAt DateTime @default(now())

  room    Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies Message[] @relation("MessageReplies")

  receipts    MessageReceipt[]
  attachments Attachment[]

  @@index([roomId, createdAt])
  @@index([userId, createdAt])
  @@index([roomId, id])
}

enum AttachmentKind {
  IMAGE
  FILE
}

/// Binary payload metadata; may exist before a message claims it (messageId null while pending upload).
model Attachment {
  id        String         @id @default(uuid())
  kind      AttachmentKind
  fileName  String
  mimeType  String
  sizeBytes Int
  url       String
  createdAt DateTime       @default(now())

  roomId     String
  messageId  String?
  uploaderId String

  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User     @relation("UserUploads", fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([messageId])
  @@index([uploaderId, createdAt])
  @@index([roomId, kind, createdAt])
}

enum ReceiptStatus {
  DELIVERED
  READ
}

/// Per-user delivery/read state for a message (composite PK includes status).
model MessageReceipt {
  messageId String
  userId    String
  status    ReceiptStatus
  at        DateTime      @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, status])
  @@index([userId, at])
  @@index([messageId, status, at])
}
