PORT=4000
# Comma-separated origins for CORS + Socket.IO. When using ngrok, include both local and public, e.g.:
# FRONTEND_URL=http://localhost:3000,https://YOUR-SUBDOMAIN.ngrok-free.dev
FRONTEND_URL=http://localhost:3000

# Prisma
# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/selam_collab?schema=public

# Optional: prefix all REST routes (e.g. api/v1)
API_PREFIX=api/v1

# JWT verification (recommended for production)
JWT_SECRET=change-me
# If unset, verification happens when JWT_SECRET is present. For dev you can disable:
REQUIRE_JWT_VERIFY=true

# Socket.IO hardening (recommended for production)
SOCKET_REQUIRE_AUTH=true
SOCKET_ALLOW_ANON=false
SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=20000
SOCKET_MAX_HTTP_BUFFER_BYTES=1000000

